{
  "registry": "HeadyBee Templates",
  "version": "1.0",
  "sourceOfTruth": "configs/services/headybee-template-registry.json",
  "predictedSituations": ["incident-response", "digital-presence-launch", "health-check"],
  "templates": [
    {
      "id": "incident-response-template",
      "name": "Incident Response",
      "domain": "incident-response",
      "zone": "critical",
